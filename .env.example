# Google Health desktop OAuth credentials.
# Create an OAuth client ID of type "Desktop app" in Google Cloud Console,
# enable the Google Health API, and add yourself as a Test user.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=yyyy

# Preview the "Connected" design with realistic placeholder data, without
# wiring Google at all. Set to 1 to force the demo data source.
STEPWISE_DEMO=0

# Auto-update signing (release builds only — not needed for `npm run tauri dev`).
# The shared updater key signs the update payload that installed apps verify
# against the pubkey in src-tauri/tauri.conf.json. Generate once with
# `npx tauri signer generate -w ~/.tauri/stepwise-updater.key` and copy the SAME
# key to every build machine (Mac + Windows). Use TAURI_SIGNING_PRIVATE_KEY (the
# build ignores the *_PATH variant). It accepts a file path or the key contents.
# Set the password to "" if the key has none.
# TAURI_SIGNING_PRIVATE_KEY=/Users/you/.tauri/stepwise-updater.key
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
